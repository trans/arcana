#!/bin/sh
set -e

case "$1" in
    purge)
        # Remove system user and state on purge.
        if getent passwd arcana >/dev/null; then
            deluser --quiet --system arcana || true
        fi
        rm -rf /var/lib/arcana /etc/arcana
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
esac

#DEBHELPER#

exit 0
