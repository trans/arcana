# Arcana bus server configuration (non-secret defaults).
# Restart the service after editing: sudo systemctl restart arcana
#
# API keys and other secrets go in /etc/arcana/secrets.env (not this file).
# See /usr/share/doc/arcana/secrets.env.example for the expected keys.

# Bind address and port. Default binds to localhost only — do not expose
# beyond 127.0.0.1 without additional transport security (TLS, firewall, etc).
ARCANA_HOST=127.0.0.1
ARCANA_PORT=19118

# State directory for snapshot persistence. The systemd unit sets this
# explicitly to /var/lib/arcana; override here if you need a different path.
#ARCANA_STATE_DIR=/var/lib/arcana
